.tag-cloud
  &-list
    line-height: 2.4

    a
      // 玻璃标签
      position: relative
      display: inline-flex
      align-items: center
      margin: 6px
      padding: 5px 8px 5px 14px
      border: 1px solid var(--glass-border)
      border-radius: 8px
      background: var(--glass-bg)
      box-shadow: var(--card-box-shadow)
      backdrop-filter: saturate(180%) blur(12px)
      -webkit-backdrop-filter: saturate(180%) blur(12px)
      color: var(--font-color)
      transition: all .3s

      &:hover
        background: alpha($theme-color, .18)
        box-shadow: var(--card-hover-box-shadow)
        color: $theme-color
        transform: translateY(-2px)

      .tag-cloud-count
        margin-left: 8px
        padding: 0 7px
        border-radius: 6px
        background: alpha($theme-color, .15)
        color: $theme-color
        font-size: .8em
        font-weight: 600

      &:hover .tag-cloud-count
        background: alpha($theme-color, .3)

      +maxWidth768()
        zoom: .9

// 标签使用统计（纯 CSS 柱状图）
.tag-chart
  margin: 44px auto 0
  max-width: 720px
  text-align: left

  &-title
    margin-bottom: 18px
    color: var(--text-highlight-color)
    font-weight: 600
    font-size: 1.3em

  &-row
    display: flex
    align-items: center
    margin: 12px 0
    color: var(--font-color)

    &:hover
      .tag-chart-fill
        background: alpha($theme-color, .95)

      .tag-chart-name
        color: $theme-color

  &-name
    overflow: hidden
    flex: 0 0 90px
    text-overflow: ellipsis
    white-space: nowrap
    font-size: .92em
    transition: color .3s

    +maxWidth768()
      flex-basis: 64px

  &-track
    overflow: hidden
    flex: 1
    height: 16px
    border-radius: 999px
    background: alpha($theme-color, .1)

  &-fill
    height: 100%
    border-radius: 999px
    background: linear-gradient(90deg, alpha($theme-color, .55), alpha($theme-color, .85))
    transition: width .8s cubic-bezier(.4, 0, .2, 1), background .3s

  &-value
    flex: 0 0 auto
    margin-left: 12px
    min-width: 24px
    color: var(--card-meta)
    text-align: right
    font-weight: 600
    font-size: .9em
