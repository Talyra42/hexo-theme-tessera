// Tessera 首页开屏模块（home_top）
if hexo-config('home_top') && hexo-config('home_top.enable')
  #home-top
    display: flex
    margin: 0 auto
    padding: 96px 15px 0
    max-width: 1400px
    width: 100%

    // ≤900px 与下方布局同步：侧栏消失，开屏模块堆叠
    +maxWidth900()
      flex-direction: column
      gap: 16px

    +maxWidth768()
      padding: 90px 12px 0

  // 有开屏模块时，正文区的顶部留白收窄
  #home-top ~ .layout
    padding-top: 16px

  // 左列与下方文章区同宽（74%），右侧推荐位与侧栏同宽（26% - 15px 内距）
  .home-top-left
    display: flex
    flex-direction: column
    gap: 16px
    width: 74%
    min-width: 0

    +maxWidth900()
      width: 100%

  // ---- 标语卡 + 图标墙 ----
  .htop-banner
    @extend .cardHover
    position: relative
    overflow: hidden
    padding: 34px 38px
    height: 256px

    +maxWidth768()
      padding: 24px 22px
      height: 200px

    .htop-text
      position: relative
      z-index: 2

    .htop-title
      color: var(--text-highlight-color)
      font-weight: 700
      font-size: 2.3em
      line-height: 1.35

      +maxWidth768()
        font-size: 1.7em

    .htop-site
      margin-top: 14px
      color: var(--card-meta)
      font-weight: 600
      font-size: .85em
      letter-spacing: 2px

    // 图标墙：两行反向滚动，左缘渐隐过渡，整体轻微倾斜
    .htop-iconwall
      position: absolute
      top: 50%
      right: -30px
      z-index: 1
      width: 58%
      transform: translateY(-50%) rotate(-8deg)
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 22%, #000 92%, transparent)
      mask-image: linear-gradient(90deg, transparent, #000 22%, #000 92%, transparent)

      +maxWidth768()
        right: -50px
        width: 80%
        opacity: .4

    .htop-iconrow
      overflow: hidden
      margin: 7px 0

    .htop-icontrack
      display: flex
      width: max-content
      animation: htop-marquee 36s linear infinite
      will-change: transform
      transform: translateZ(0)

    .htop-reverse .htop-icontrack
      animation-direction: reverse

    .htop-tile
      display: flex
      flex-shrink: 0
      margin-right: 14px // 用 margin 而非 gap：保证 -50% 位移无缝循环
      justify-content: center
      align-items: center
      width: 62px
      height: 62px
      border-radius: 16px
      color: #fff
      font-size: 30px
      box-shadow: 0 6px 14px rgba(0, 0, 0, .14)

      +maxWidth768()
        width: 48px
        height: 48px
        border-radius: 12px
        font-size: 23px

  // ---- 分类入口卡 ----
  .htop-categories
    display: flex
    gap: 16px

    +maxWidth768()
      gap: 10px

  .htop-cat
    position: relative
    overflow: hidden
    display: flex
    flex: 1
    align-items: center
    padding: 0 24px
    height: 84px
    border-radius: var(--card-radius)
    color: #fff !important
    transition: transform .3s ease, box-shadow .3s ease

    +maxWidth768()
      padding: 0 14px
      height: 64px

    .htop-cat-name
      position: relative
      z-index: 2
      font-weight: 700
      font-size: 1.18em
      text-decoration: underline rgba(255, 255, 255, .5) 2px
      text-underline-offset: 5px

      +maxWidth768()
        font-size: 1em

    .htop-cat-icon
      position: absolute
      right: 14px
      bottom: -12px
      z-index: 1
      color: rgba(255, 255, 255, .35)
      font-size: 56px
      transform: rotate(-15deg)
      transition: transform .4s ease, font-size .4s ease

      +maxWidth768()
        font-size: 40px

    &:hover
      box-shadow: 0 12px 26px -6px rgba(0, 0, 0, .35)
      transform: translateY(-3px)

      .htop-cat-icon
        transform: rotate(0deg) scale(1.18)

  // ---- 推荐位横幅 ----
  .htop-recommend
    @extend .cardHover
    position: relative
    overflow: hidden
    display: block
    margin-left: 15px
    width: calc(26% - 15px)
    background-position: center
    background-size: cover
    padding: 0

    +maxWidth900()
      margin-left: 0
      width: 100%
      height: 190px

    .htop-rec-mask
      position: absolute
      inset: 0
      background: linear-gradient(180deg, rgba(10, 12, 26, .72), rgba(10, 12, 26, .06) 62%)
      transition: background .3s ease

    .htop-rec-info
      position: absolute
      top: 18px
      left: 22px
      z-index: 2
      color: #fff

      .htop-rec-tips
        margin-bottom: 2px
        opacity: .75
        font-size: .82em

      .htop-rec-title
        font-weight: 700
        font-size: 1.35em
        line-height: 1.35

    .htop-rec-btn
      position: absolute
      right: 18px
      bottom: 20px
      z-index: 2
      display: flex
      gap: 7px
      align-items: center
      padding: 7px 14px
      border-radius: 24px
      background: rgba(255, 255, 255, .16)
      color: #fff
      font-size: .85em
      backdrop-filter: blur(8px)
      -webkit-backdrop-filter: blur(8px)
      transition: background .3s ease

    &:hover
      .htop-rec-btn
        background: var(--tessera-primary)

      .htop-rec-mask
        background: linear-gradient(180deg, rgba(10, 12, 26, .8), rgba(10, 12, 26, .15) 62%)

  @keyframes htop-marquee
    to
      transform: translateX(-50%)
