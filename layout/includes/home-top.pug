//- Tessera 首页开屏模块（致敬安知鱼 home_top）
//- 左：标语卡（含滚动图标墙）+ 分类入口卡；右：推荐位横幅
- const ht = theme.home_top
- const icons = ht.icons || []
- const row1 = icons.filter((v, i) => i % 2 === 0)
- const row2 = icons.filter((v, i) => i % 2 === 1)
- const cats = ht.category || []
- const bn = ht.banner

#home-top
  .home-top-left
    .htop-banner
      .htop-text
        .htop-title= ht.title
        .htop-title= ht.subTitle
        if ht.siteText
          .htop-site= ht.siteText
      if icons.length
        .htop-iconwall(aria-hidden='true')
          .htop-iconrow
            .htop-icontrack
              each it in row1.concat(row1)
                .htop-tile(style=`background:${it.color}`)
                  i(class=it.icon)
          if row2.length
            .htop-iconrow.htop-reverse
              .htop-icontrack
                each it in row2.concat(row2)
                  .htop-tile(style=`background:${it.color}`)
                    i(class=it.icon)
    if cats.length
      .htop-categories
        each c in cats
          a.htop-cat(href=url_for(c.path) style=`background:${c.color}`)
            span.htop-cat-name= c.name
            if c.icon
              i.htop-cat-icon(class=c.icon)
  if bn && bn.enable !== false
    - const bnStyle = bn.image ? `background-image:url(${url_for(bn.image)})` : 'background:linear-gradient(135deg,#1b1f3a,#425AEF)'
    a.htop-recommend(href=url_for(bn.link || '/') style=bnStyle)
      .htop-rec-mask
      .htop-rec-info
        if bn.tips
          .htop-rec-tips= bn.tips
        .htop-rec-title= bn.title
      .htop-rec-btn
        i.fas.fa-circle-arrow-right
        span= bn.button || '更多推荐'
